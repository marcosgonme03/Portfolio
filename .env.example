# ============================================================
# VARIABLES DE ENTORNO — Portfolio Backend (PLANTILLA)
# ────────────────────────────────────────────────────────────
# 1. Copia este archivo como .env  (cp .env.example .env)
# 2. Rellena los valores reales en .env
# 3. NUNCA subas el .env real a Git (está en .gitignore)
# 4. Tampoco escribas valores reales en este .env.example
# ============================================================

# Puerto del servidor en local. En Render/Railway lo asignan ellos.
PORT=3001

# Dominios permitidos en CORS — separados por coma si hay varios.
# En desarrollo, los localhost ya están allowlistados por el código.
# En producción, pon aquí el dominio de tu portfolio:
ALLOWED_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# ─────────────────────────────────────────
# CONFIGURACIÓN DE GMAIL PARA NODEMAILER
# ─────────────────────────────────────────
# Tu email de Gmail (el que envía los mensajes)
GMAIL_USER=tucuenta@gmail.com

# Contraseña de aplicación de Google (16 caracteres, NO tu contraseña normal)
# Cómo obtenerla:
#   1. Ve a https://myaccount.google.com/security
#   2. Activa "Verificación en 2 pasos" si no la tienes
#   3. Ve a https://myaccount.google.com/apppasswords
#   4. Crea una app → Correo → Otro → copia la contraseña
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Email donde recibirás los mensajes del formulario
CONTACT_RECIPIENT=tucuenta@gmail.com
